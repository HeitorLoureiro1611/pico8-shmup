pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()

 variavel=0
-- posicao da nave
	navex=61
	navey=100
-- sprite da nave
	navespr=2
	fogospr=5
-- posicao do tiro
	tirox=0
	tiroy=0
-- velocidade do tiro
	tirospd=4
-- sprite do tiro
	tirospr=16

end

function _update()

-- solta o botao e a nave para
-- nave (s)peed
	navesx=0
	navesy=0
	navespr=2

	
	cls(0)
	
-- logica da colisao

	if (navex<0) navex=0
	if (navex>120) navex=120
	if (navey<0) navey=0
	if (navey>120) navey=120

-- botoes
--	botoes mudam a direcao nave
	if btn(➡️) then
	 navesx=2
	 navespr=3
	end
	
	if (btn(⬅️)) then
	 navesx=-2
		navespr=1
	end
	
	if (btn(⬇️)) navesy=2
	if (btn(⬆️)) then 
		navesy=-2
	end

-- botao de tiro
	if btnp(❎) then
		tiroy=navey
		tirox=navex
		sfx(0)
	end
	
-- logica da movimentacao
-- nave
	navex+=navesx
	navey+=navesy

-- tiro
	tiroy-=tirospd

-- animacao do fogo na nave
 fogospr+=1
 if(fogospr==9)fogospr=5

end

function _draw()
	
	-- mostra a nave
	spr(navespr,navex,navey)
	spr(fogospr,navex,navey+9)
	spr(tirospr,tirox,tiroy-4)

end
