pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	score=10000

	vidas=4
	vidasmax=4

	especialat=3
	especialmax=3
	
-- posicao da nave
	navex=61
	navey=100
-- sprite da nave
	navespr=2
	fogospr=5
-- posicao do tiro
	tirox=0
	tiroy=0
-- velocidade do tiro
	tirospd=4
-- sprite do tiro
	tirospr=16
-- brilho de tiro
 flashtam=0
 
 estrelax={}
	estrelay={}
	for i=1,50 do
		add(estrelax,flr(rnd(128)))
		add(estrelay,flr(rnd(128)))
	end


end

function _update()

-- solta o botao e a nave para
-- nave (s)peed
	navesx=0
	navesy=0
	navespr=2

	
	cls(0)
	field()
-- logica da colisao

	if (navex<0) navex=0
	if (navex>120) navex=120
	if (navey<0) navey=0
	if (navey>120) navey=120

-- botoes
--	botoes mudam a direcao nave
	if btn(➡️) then
	 navesx=2
	 navespr=3
	end
	
	if btn(⬅️) then
	 navesx=-2
		navespr=1
	end
	
	if (btn(⬇️)) navesy=2
	
	if btn(⬆️) then 
		navesy=-2
	end

-- botao de tiro
	if btnp(❎) then
		flashtam=7
		tiroy=navey
		tirox=navex
		sfx(0)
	end

-- ##############################
--   logica das coisas
-- ##############################
-- 
-- logica do tamanho do brilho
	flashtam-=1 -- velocidade

-- logica da movimentacao
-- nave
	navex+=navesx
	navey+=navesy

-- tiro se movimentando
	tiroy-=tirospd
	
-- animacao do tiro
	tirospr+=1
	if (tirospr==19) tirospr=16

-- animacao do fogo na nave
 fogospr+=1
 if(fogospr==8)fogospr=4

end

function _draw()
	
	-- mostra a nave
	spr(navespr,navex,navey)
	if flashtam > 0 then
		circfill(navex+3, navey-1, flashtam, 7)
	end
	spr(fogospr,navex,navey+9)
	spr(tirospr,tirox,tiroy-4)
	
	for i=1,vidasmax do
		if vidas>=i then
			spr(9,i*10-9,1)
		else
			spr(10,i*10-9,1)
		end
	end
	
	for i=1,especialmax do
		if especialat>=i then
			spr(11,(i*10-9)+89,1)
		else
			spr(12,(i*10-9)+89,1)
		end
	end
	print("score: "..score,40,1,12)
end
-->8
function field()
	for i=1,50 do
		pset(estrelax[i],estrelay[i],7)
	end
end
